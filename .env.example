# Foundry environment variables
# Copy to .env and fill in as needed. All are optional — config.toml is primary.

# Server
FOUNDRY_PORT=8120
FOUNDRY_DATA_DIR=~/.foundry

# Agent providers (set keys here or in config.toml)
FOUNDRY_OPENAI_API_KEY=
FOUNDRY_ANTHROPIC_API_KEY=

# GitHub
FOUNDRY_GITHUB_TOKEN=

# Auth (for remote access)
FOUNDRY_AUTH_PIN=

# Internal
FOUNDRY_SECRET_KEY=
FOUNDRY_LOG_LEVEL=INFO
